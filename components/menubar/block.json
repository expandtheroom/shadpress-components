      "data": {
        "menus": [
          {
            "label": "File",
            "items": [
              { "type": "item", "label": "New", "href": "#" },
              { "type": "separator" },
              { "type": "item", "label": "Exit", "href": "#" }
            ]
          },
          {
            "label": "Edit",
            "items": [
              { "type": "item", "label": "Undo", "href": "#" },
              { "type": "item", "label": "Redo", "href": "#" }
            ]
          }
        ]
      }
    }
  }
}
