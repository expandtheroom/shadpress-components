{
  "$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",

  "apiVersion": 3,

  "name": "acf/checkbox-group-field",

  "title": "Checkbox Group Field",

  "category": "theme",

  "description": "Group of checkboxes sharing a name, submitting selected values as an array",

  "keywords": [
    "Checkbox Group Field",
    "theme"
  ],

  "textdomain": "etr-starter-theme",

  "supports": {
    "anchor": true,
    "customClassName": true
  },

  "acf": {
    "blockVersion": 3
  },

  "example": {
    "attributes": {
      "mode": "preview",
      "data": {
        "label": "Preferred contact methods",
        "name": "contact_methods",
        "orientation": "vertical",
        "options": [
          { "label": "Email", "value": "email", "checked": true },
          { "label": "Phone", "value": "phone", "checked": false },
          { "label": "SMS", "value": "sms", "checked": false }
        ]
      }
    }
  }
}
