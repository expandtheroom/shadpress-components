{
  "$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",

  "apiVersion": 3,

  "name": "acf/form-field",

  "title": "Form Field",

  "category": "theme",

  "description": "Form Field",

  "keywords": ["Form Field", "theme"],

  "textdomain": "shadpress",

  "supports": {
    "anchor": true,
    "customClassName": true
  },

  "acf": {
    "blockVersion": 3
  },

  "example": {
    "attributes": {
      "mode": "preview",
      "data": {
        "control_type": "input",
        "input_fields": {
          "label": "Email address",
          "label_for": "email",
          "field_type": "email",
          "placeholder": "you@example.com",
          "description": "We'll never share your email.",
          "required": true
        }
      }
    }
  }
}
