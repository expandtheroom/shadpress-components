{
  "$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",

  "apiVersion": 3,

  "name": "acf/native-select",

  "title": "Native Select",

  "category": "theme",

  "description": "Native Select",

  "keywords": ["Native Select", "theme"],

  "textdomain": "shadpress-starter",

  "supports": {
    "anchor": true,
    "customClassName": true
  },

  "acf": {
    "blockVersion": 3
  },

  "example": {
    "attributes": {
      "mode": "preview",
      "data": {
        "placeholder": "Choose a country",
        "name": "country",
        "items": [
          { "label": "Croatia", "value": "hr" },
          { "label": "Germany", "value": "de" }
        ]
      }
    }
  }
}
