{
  "$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",

  "apiVersion": 3,

  "name": "acf/table",

  "title": "Table",

  "category": "theme",

  "description": "Table",

  "keywords": ["Table", "theme"],

  "textdomain": "shadpress-starter",

  "supports": {
    "anchor": true,
    "customClassName": true
  },

  "acf": {
    "blockVersion": 3
  },

  "example": {
    "attributes": {
      "mode": "preview",
      "data": {
        "caption": "A list of recent invoices",
        "headers": [
          { "label": "Invoice" },
          { "label": "Status" },
          { "label": "Method" },
          { "label": "Amount" }
        ],
        "rows": [
          {
            "cells": [
              { "content": "INV001" },
              { "content": "Paid" },
              { "content": "Credit Card" },
              { "content": "$250.00" }
            ]
          },
          {
            "cells": [
              { "content": "INV002" },
              { "content": "Pending" },
              { "content": "PayPal" },
              { "content": "$150.00" }
            ]
          },
          {
            "cells": [
              { "content": "INV003" },
              { "content": "Unpaid" },
              { "content": "Bank Transfer" },
              { "content": "$350.00" }
            ]
          }
        ]
      }
    }
  }
}
