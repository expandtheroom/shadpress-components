{
  "$schema": "https://advancedcustomfields.com/schemas/json/main/block.json",

  "apiVersion": 3,

  "name": "acf/styled-select-field",

  "title": "Styled Select Field",

  "category": "theme",

  "description": "Styled Select Field",

  "keywords": ["Styled Select Field", "theme"],

  "textdomain": "shadpress",

  "supports": {
    "anchor": true,
    "customClassName": true
  },

  "acf": {
    "blockVersion": 3
  },

  "example": {
    "attributes": {
      "mode": "preview",
      "data": {
        "name": "timezone",
        "placeholder": "Select timezone",
        "items": [
          { "label": "UTC", "value": "utc" },
          { "label": "Europe/Zagreb", "value": "europe_zagreb" }
        ]
      }
    }
  }
}
